DISCOGS_PERSONAL_ACCESS_TOKEN=your_token_here
DISCOGS_USERNAME=your_discogs_username_here

# Same Spotify app registration as C:\Scripts\spotify-mcp\.env. Add this redirect
# URI to the app in the Spotify Developer Dashboard before using Spotify features here.
SPOTIFY_CLIENT_ID=your_client_id_here
SPOTIFY_CLIENT_SECRET=your_client_secret_here
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8001/callback

# Same Last.fm API key as C:\Scripts\lastfm-mcp\.env
LASTFM_API_KEY=your_lastfm_api_key_here
LASTFM_USER=your_lastfm_username_here

# Used for /ask, playlist-idea generation, and genre primers
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Free-tier "second opinion" reviewer for field-trip playlists (https://console.groq.com)
GROQ_API_KEY=your_groq_api_key_here

# Tour radar (Shows tab). Free self-serve key: https://developer.ticketmaster.com
# TICKETMASTER_LOCATION is your home postal/ZIP code, used as the search-radius center.
TICKETMASTER_API_KEY=your_ticketmaster_api_key_here
TICKETMASTER_LOCATION=your_postal_code_here

# Pre-show playlists (Shows tab). Free non-commercial key: https://api.setlist.fm
SETLISTFM_API_KEY=your_setlistfm_api_key_here

# Import your Songkick-tracked shows (Shows tab) via the public per-user iCal feed — no API key
# needed (Songkick's API key program is currently closed to new applicants).
SONGKICK_USERNAME=your_songkick_username_here
